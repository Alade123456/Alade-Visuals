{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A user's task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "dueDate": { "type": "string" },
        "dueTime": { "type": "string" },
        "reminder": { "type": "boolean" },
        "repeat": { "type": "string", "enum": ["None", "Daily", "Weekly", "Monthly"] },
        "colorLabel": { "type": "string" },
        "duration": { "type": "number" },
        "subtasks": { "type": "array" },
        "notes": { "type": "string" },
        "completed": { "type": "boolean" },
        "completedAt": { "type": "string" },
        "pinned": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "name", "priority", "completed"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A user's habit",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "frequency": { "type": "string", "enum": ["Daily", "Weekly"] },
        "streak": { "type": "number" },
        "bestStreak": { "type": "number" },
        "history": { "type": "object" },
        "paused": { "type": "boolean" },
        "colorLabel": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "name", "frequency", "streak", "bestStreak", "history", "paused"]
    },
    "UserPreference": {
      "title": "User Preference",
      "description": "Preferences for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "darkMode": { "type": "boolean" },
        "notificationReminders": { "type": "boolean" },
        "reminderTimes": { "type": "string" },
        "startOfWeek": { "type": "string", "enum": ["Monday", "Sunday"] },
        "timeFormat": { "type": "string", "enum": ["12h", "24h"] },
        "defaultHomeMode": { "type": "string", "enum": ["Productivity", "Habits"] },
        "themeColor": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "darkMode", "themeColor"]
    }
  },
  "firestore": {
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks created by the user"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "#/entities/Habit" },
      "description": "Habits created by the user"
    },
    "/users/{userId}/preferences/{preferenceId}": {
      "schema": { "$ref": "#/entities/UserPreference" },
      "description": "User preferences"
    }
  }
}
